# ============================================================
# Clinical ETL — Environment Configuration (PLACEHOLDERS)
# ============================================================

APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Oracle (Legacy EHR) ---
ORACLE_HOST=ehr.example.com
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=EHRPROD
ORACLE_USER=clinical_etl_reader
ORACLE_PASSWORD=__PLACEHOLDER__

# --- PostgreSQL (ODS) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=clinical_etl_ods
POSTGRES_USER=clinical_etl
POSTGRES_PASSWORD=__PLACEHOLDER__

# --- FHIR API ---
FHIR_BASE_URL=https://fhir.example.com/r4
FHIR_CLIENT_ID=__PLACEHOLDER__
FHIR_CLIENT_SECRET=__PLACEHOLDER__
FHIR_TOKEN_URL=https://fhir.example.com/oauth/token

# --- SFTP (Lab files) ---
SFTP_HOST=labs-sftp.example.com
SFTP_PORT=22
SFTP_USER=clinical_etl_etl
SFTP_KEY_PATH=/secrets/sftp_rsa
SFTP_REMOTE_DIR=/inbound/labs

# --- EDI 837/835 (Claims) ---
EDI_INBOUND_DIR=data/raw/edi
EDI_PARTNER_ID=__PLACEHOLDER__

# --- Azure ADLS ---
AZURE_STORAGE_ACCOUNT=clinical_etladls
AZURE_STORAGE_KEY=__PLACEHOLDER__
AZURE_CONTAINER=clinical_etl
AZURE_BLOB_PREFIX=delta/

# --- Elasticsearch ---
ES_HOSTS=http://localhost:9200
ES_USER=elastic
ES_PASSWORD=__PLACEHOLDER__
ES_INDEX_PATIENT=patients
ES_INDEX_ENCOUNTER=encounters

# --- Redis (Celery broker + DLQ + audit) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_DLQ_KEY=clinical_etl:dlq

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIME_LIMIT=600

# --- Matching ---
MATCH_AUTO_MERGE_THRESHOLD=0.85
MATCH_REVIEW_THRESHOLD=0.65
MATCH_DOB_TOLERANCE_DAYS=1

# --- PHI Masking ---
MASKING_ENABLED=true
MASKING_RULES_PATH=config/masking_rules.yaml
MASKING_SALT=__PLACEHOLDER__

# --- Audit ---
AUDIT_LOG_PATH=logs/hipaa_audit.jsonl
